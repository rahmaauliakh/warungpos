<aside class="w-full border-b border-blue-800/40 bg-gradient-to-b from-blue-700 via-blue-700 to-blue-900 text-white lg:min-h-screen lg:w-72 lg:border-b-0 lg:border-r lg:border-blue-900/40">
  <div class="px-6 py-6">
    <p class="text-xs uppercase tracking-[0.35em] text-blue-100/70">WarungPOS</p>
    <h1 class="mt-2 text-2xl font-semibold"><%= sidebarTitle || 'Dashboard' %></h1>
    <% if (typeof sidebarDescription !== "undefined" && sidebarDescription) { %>
      <p class="mt-3 text-sm text-blue-100/80"><%= sidebarDescription %></p>
    <% } %>
  </div>

  <nav class="space-y-2 px-4">
    <% (sidebarLinks || []).forEach((link) => { %>
      <% const isActive = currentPath === link.href || (link.matchPrefix && currentPath.startsWith(link.matchPrefix)); %>
      <% if (link.href) { %>
        <a
          href="<%= link.href %>"
          class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition <%= isActive ? 'bg-white/15 text-white shadow-lg shadow-blue-950/20' : 'text-blue-100/80 hover:bg-white/10 hover:text-white' %>"
        >
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl <%= isActive ? 'bg-white/15' : 'bg-white/10' %>">
            <span class="text-xs font-bold"><%= link.short || link.label.slice(0, 1) %></span>
          </span>
          <%= link.label %>
        </a>
      <% } else { %>
        <div class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm text-blue-100/80">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-white/10">
            <span class="text-xs font-bold"><%= link.short || link.label.slice(0, 1) %></span>
          </span>
          <%= link.label %>
        </div>
      <% } %>
    <% }) %>
  </nav>

  <div class="mt-8 border-t border-white/10 px-6 py-5">
    <div class="rounded-3xl bg-white/10 p-4 backdrop-blur">
      <p class="text-sm font-medium text-white"><%= sessionUser?.nama || sessionUser?.email %></p>
      <p class="mt-1 text-xs text-blue-100/75">Role <%= sessionUser?.role || 'user' %></p>
      <form action="/logout" method="POST" class="mt-4">
        <button type="submit" class="w-full rounded-2xl bg-white px-4 py-2.5 text-sm font-semibold text-blue-700 transition hover:bg-blue-50">
          Logout
        </button>
      </form>
    </div>
  </div>
</aside>
