<aside class="w-full border-b border-slate-200 bg-slate-950 text-white lg:min-h-screen lg:w-72 lg:border-b-0 lg:border-r lg:border-slate-800">
  <div class="px-6 py-6">
    <p class="text-xs uppercase tracking-[0.35em] text-slate-400">WarungPOS</p>
    <h1 class="mt-2 text-2xl font-semibold"><%= sidebarTitle || 'Dashboard' %></h1>
    <% if (typeof sidebarDescription !== "undefined" && sidebarDescription) { %>
      <p class="mt-3 text-sm text-slate-400"><%= sidebarDescription %></p>
    <% } %>
  </div>

  <nav class="space-y-2 px-4">
    <% (sidebarLinks || []).forEach((link) => { %>
      <% const isActive = currentPath === link.href || (link.matchPrefix && currentPath.startsWith(link.matchPrefix)); %>
      <% if (link.href) { %>
        <a
          href="<%= link.href %>"
          class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition <%= isActive ? 'bg-white/10 text-white' : 'text-slate-300 hover:bg-white/5 hover:text-white' %>"
        >
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl <%= isActive ? 'bg-white/10' : 'bg-white/5' %>">
            <span class="text-xs font-bold"><%= link.short || link.label.slice(0, 1) %></span>
          </span>
          <%= link.label %>
        </a>
      <% } else { %>
        <div class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm text-slate-300">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-white/5">
            <span class="text-xs font-bold"><%= link.short || link.label.slice(0, 1) %></span>
          </span>
          <%= link.label %>
        </div>
      <% } %>
    <% }) %>
  </nav>

  <div class="mt-8 border-t border-slate-800 px-6 py-5">
    <div class="rounded-3xl bg-white/5 p-4">
      <p class="text-sm font-medium text-white"><%= sessionUser?.nama || sessionUser?.email %></p>
      <p class="mt-1 text-xs text-slate-400">Role <%= sessionUser?.role || 'user' %></p>
      <form action="/logout" method="POST" class="mt-4">
        <button type="submit" class="w-full rounded-2xl bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-slate-100">
          Logout
        </button>
      </form>
    </div>
  </div>
</aside>
