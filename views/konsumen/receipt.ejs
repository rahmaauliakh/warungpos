<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900">
  <main class="mx-auto flex min-h-screen max-w-5xl flex-col items-center px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-5 flex w-full max-w-md flex-wrap items-center justify-between gap-3">
      <a href="/konsumen/history" class="rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50">
        Kembali
      </a>
      <a href="/konsumen/receipt/<%= transaction.invoice %>/download" class="rounded-2xl bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800">
        Download Struk
      </a>
    </div>

    <section class="w-full max-w-md bg-white px-6 py-7 shadow-[0_24px_60px_rgba(15,23,42,0.10)] ring-1 ring-slate-200 print:shadow-none print:ring-0">
      <header class="text-center">
        <p class="text-xl font-bold tracking-wide text-slate-950">WARUNGPOS</p>
        <p class="mt-1 text-xs text-slate-500">Struk Transaksi</p>
        <p class="text-xs text-slate-500">Terima kasih sudah berbelanja</p>
      </header>

      <div class="my-5 border-t border-dashed border-slate-300"></div>

      <dl class="space-y-2 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Invoice</dt>
          <dd class="break-all text-right font-medium text-slate-950"><%= transaction.invoice %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Tanggal</dt>
          <dd class="text-right font-medium text-slate-950"><%= transaction.created_at_formatted %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Status</dt>
          <dd class="text-right font-medium text-slate-950"><%= transaction.status_meta.label %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Pembayaran</dt>
          <dd class="text-right font-medium text-slate-950"><%= transaction.payment_method || '-' %></dd>
        </div>
      </dl>

      <div class="my-5 border-t border-dashed border-slate-300"></div>

      <div class="space-y-4">
        <% items.forEach((item) => { %>
          <article>
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= item.nama_produk || 'Produk' %></p>
                <p class="mt-1 text-xs text-slate-500"><%= item.kategori || 'Umum' %></p>
              </div>
              <p class="shrink-0 text-sm font-semibold text-slate-950"><%= item.subtotal_formatted %></p>
            </div>
            <p class="mt-1 text-sm text-slate-500"><%= item.qty %> x <%= item.price_formatted %></p>
          </article>
        <% }) %>
      </div>

      <div class="my-5 border-t border-dashed border-slate-300"></div>

      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-slate-500">Subtotal</dt>
          <dd class="font-medium text-slate-950"><%= transaction.subtotal_formatted %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-slate-500">Fee</dt>
          <dd class="font-medium text-slate-950"><%= transaction.fee_formatted %></dd>
        </div>
        <div class="flex justify-between border-t border-slate-200 pt-3 text-base">
          <dt class="font-bold text-slate-950">Total</dt>
          <dd class="font-bold text-slate-950"><%= transaction.grand_total_formatted %></dd>
        </div>
      </dl>

      <div class="my-5 border-t border-dashed border-slate-300"></div>

      <footer class="text-center text-xs leading-5 text-slate-500">
        <p><%= transaction.status_meta.description %></p>
        <p class="mt-2">Simpan struk ini sebagai bukti transaksi.</p>
      </footer>
    </section>
  </main>
</body>
</html>
