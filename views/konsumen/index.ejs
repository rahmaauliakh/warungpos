<%- include("../partials/header", { pageTitle, bodyClass: "bg-slate-100 text-slate-900" }) %>
  <div class="min-h-screen">
    <header class="sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
        <div>
          <p class="text-xs uppercase tracking-[0.35em] text-slate-400">WarungPOS</p>
          <h1 class="mt-1 text-2xl font-semibold tracking-tight text-slate-950">Product Catalog</h1>
        </div>

        <div class="flex items-center gap-3">
          <div class="hidden rounded-2xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-600 sm:block">
            <span class="font-medium text-slate-900"><%= sessionUser?.nama || sessionUser?.email %></span>
          </div>
          <form action="/logout" method="POST">
            <button type="submit" class="rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
              Logout
            </button>
          </form>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
      <% if (typeof catalogError !== 'undefined' && catalogError) { %>
        <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
          <%= catalogError %>
        </div>
      <% } %>

      <section class="overflow-hidden rounded-[28px] bg-gradient-to-r from-slate-950 via-slate-900 to-slate-800 px-6 py-8 text-white shadow-soft sm:px-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)] lg:items-end">
          <div>
            <p class="text-sm font-medium text-slate-300">Customer display</p>
            <h2 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Belanja cepat dengan tampilan katalog modern.</h2>
            <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">
              Cari produk, filter kategori, lalu tambahkan item ke cart dengan kontrol kuantitas langsung di samping katalog.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-3xl bg-white/10 p-4">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Produk</p>
              <p class="mt-2 text-2xl font-semibold"><%= products.length %></p>
            </div>
            <div class="rounded-3xl bg-white/10 p-4">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Cart</p>
              <p class="mt-2 text-2xl font-semibold"><%= cart.totalQty %></p>
            </div>
          </div>
        </div>
      </section>

      <section class="mt-6 grid gap-6 xl:grid-cols-[minmax(0,1.65fr)_380px]">
        <div class="space-y-6">
          <section class="rounded-[28px] bg-white p-5 shadow-soft ring-1 ring-slate-200 sm:p-6">
            <form action="/konsumen" method="GET" class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_240px_auto]">
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700">Cari Produk</label>
                <input
                  type="text"
                  name="search"
                  value="<%= filters.search %>"
                  placeholder="Cari berdasarkan nama produk"
                  class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-slate-400 focus:bg-white"
                >
              </div>
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700">Kategori</label>
                <select
                  name="kategori"
                  class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-slate-400 focus:bg-white"
                >
                  <option value="">Semua kategori</option>
                  <% categories.forEach((category) => { %>
                    <option value="<%= category %>" <%= filters.kategori === category ? 'selected' : '' %>><%= category %></option>
                  <% }) %>
                </select>
              </div>
              <div class="flex items-end gap-3">
                <button type="submit" class="w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
                  Terapkan
                </button>
              </div>
            </form>
          </section>

          <section class="grid gap-5 sm:grid-cols-2 2xl:grid-cols-3">
            <% if (products.length === 0) { %>
              <div class="sm:col-span-2 2xl:col-span-3 rounded-[28px] bg-white p-10 text-center shadow-soft ring-1 ring-slate-200">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-slate-100">
                  <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V7a2 2 0 00-2-2h-3V3H9v2H6a2 2 0 00-2 2v6m16 0H4m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5" />
                  </svg>
                </div>
                <h3 class="mt-4 text-xl font-semibold text-slate-950">Produk tidak ditemukan</h3>
                <p class="mt-2 text-sm text-slate-500">Coba ubah kata kunci pencarian atau filter kategori.</p>
              </div>
            <% } %>

            <% products.forEach((product) => { %>
              <article class="overflow-hidden rounded-[28px] bg-white shadow-soft ring-1 ring-slate-200">
                <div class="aspect-[4/3] overflow-hidden bg-slate-100">
                  <% if (product.gambar) { %>
                    <img src="<%= product.gambar %>" alt="<%= product.nama_produk %>" class="h-full w-full object-cover">
                  <% } else { %>
                    <div class="flex h-full items-center justify-center">
                      <svg class="h-10 w-10 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2 1.586-1.586a2 2 0 012.828 0L20 14m-8-8h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  <% } %>
                </div>
                <div class="p-5">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"><%= product.kategori || 'Umum' %></span>
                      <h3 class="mt-3 text-lg font-semibold text-slate-950"><%= product.nama_produk %></h3>
                    </div>
                    <span class="rounded-full px-3 py-1 text-xs font-semibold <%= Number(product.stock) > 0 ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                      Stock <%= product.stock %>
                    </span>
                  </div>

                  <div class="mt-5 flex items-end justify-between gap-4">
                    <div>
                      <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Harga</p>
                      <p class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">
                        <%= new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 }).format(product.harga) %>
                      </p>
                    </div>
                    <form action="/konsumen/cart/<%= product.id %>/add" method="POST">
                      <input type="hidden" name="redirect" value="/konsumen?<%= new URLSearchParams({ search: filters.search || '', kategori: filters.kategori || '' }).toString() %>">
                      <button
                        type="submit"
                        class="rounded-2xl px-4 py-3 text-sm font-semibold transition <%= Number(product.stock) > 0 ? 'bg-slate-950 text-white hover:bg-slate-800' : 'bg-slate-200 text-slate-400 cursor-not-allowed' %>"
                        <%= Number(product.stock) > 0 ? '' : 'disabled' %>
                      >
                        Tambah ke Cart
                      </button>
                    </form>
                  </div>
                </div>
              </article>
            <% }) %>
          </section>
        </div>

        <aside class="xl:sticky xl:top-24 xl:h-fit">
          <section class="overflow-hidden rounded-[28px] bg-white shadow-soft ring-1 ring-slate-200">
            <div class="border-b border-slate-200 px-5 py-5 sm:px-6">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-sm font-medium text-slate-500">Session Cart</p>
                  <h3 class="mt-1 text-2xl font-semibold text-slate-950">Keranjang Belanja</h3>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                  <%= cart.totalQty %> item
                </span>
              </div>
            </div>

            <% if (cart.items.length === 0) { %>
              <div class="p-8 text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-slate-100">
                  <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.1 5.3A1 1 0 006.9 20H19M9 20a1 1 0 102 0m6 0a1 1 0 102 0" />
                  </svg>
                </div>
                <h4 class="mt-4 text-lg font-semibold text-slate-950">Cart masih kosong</h4>
                <p class="mt-2 text-sm leading-6 text-slate-500">Tambahkan produk dari katalog untuk mulai checkout.</p>
              </div>
            <% } else { %>
              <div class="max-h-[520px] space-y-4 overflow-y-auto px-5 py-5 sm:px-6">
                <% cart.items.forEach((item) => { %>
                  <article class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                    <div class="flex gap-4">
                      <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white">
                        <% if (item.gambar) { %>
                          <img src="<%= item.gambar %>" alt="<%= item.nama_produk %>" class="h-full w-full object-cover">
                        <% } else { %>
                          <svg class="h-6 w-6 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2 1.586-1.586a2 2 0 012.828 0L20 14m-8-8h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                          </svg>
                        <% } %>
                      </div>
                      <div class="min-w-0 flex-1">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <h4 class="truncate text-sm font-semibold text-slate-950"><%= item.nama_produk %></h4>
                            <p class="mt-1 text-xs text-slate-500"><%= item.hargaFormatted %></p>
                          </div>
                          <form action="/konsumen/cart/<%= item.productId %>/remove" method="POST">
                            <input type="hidden" name="redirect" value="/konsumen?<%= new URLSearchParams({ search: filters.search || '', kategori: filters.kategori || '' }).toString() %>">
                            <button type="submit" class="rounded-xl bg-white px-2.5 py-2 text-xs font-semibold text-rose-600 ring-1 ring-slate-200 transition hover:bg-rose-50">
                              Hapus
                            </button>
                          </form>
                        </div>

                        <div class="mt-4 flex items-center justify-between gap-3">
                          <div class="inline-flex items-center rounded-2xl bg-white ring-1 ring-slate-200">
                            <form action="/konsumen/cart/<%= item.productId %>/qty" method="POST">
                              <input type="hidden" name="action" value="decrease">
                              <input type="hidden" name="redirect" value="/konsumen?<%= new URLSearchParams({ search: filters.search || '', kategori: filters.kategori || '' }).toString() %>">
                              <button type="submit" class="px-3 py-2 text-sm font-semibold text-slate-700">-</button>
                            </form>
                            <span class="min-w-10 px-2 text-center text-sm font-semibold text-slate-900"><%= item.qty %></span>
                            <form action="/konsumen/cart/<%= item.productId %>/qty" method="POST">
                              <input type="hidden" name="action" value="increase">
                              <input type="hidden" name="redirect" value="/konsumen?<%= new URLSearchParams({ search: filters.search || '', kategori: filters.kategori || '' }).toString() %>">
                              <button type="submit" class="px-3 py-2 text-sm font-semibold text-slate-700">+</button>
                            </form>
                          </div>

                          <div class="text-right">
                            <p class="text-xs text-slate-500">Subtotal</p>
                            <p class="mt-1 text-sm font-semibold text-slate-950"><%= item.totalFormatted %></p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </article>
                <% }) %>
              </div>

              <div class="border-t border-slate-200 bg-slate-50 px-5 py-5 sm:px-6">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-slate-500">Subtotal</span>
                  <span class="text-2xl font-semibold tracking-tight text-slate-950"><%= cart.subtotalFormatted %></span>
                </div>
                <form action="/konsumen/checkout" method="POST" class="mt-4">
                  <input type="hidden" name="redirect" value="/konsumen?<%= new URLSearchParams({ search: filters.search || '', kategori: filters.kategori || '' }).toString() %>">
                  <button type="submit" class="w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
                    Checkout
                  </button>
                </form>
              </div>
            <% } %>
          </section>
        </aside>
      </section>
    </main>
  </div>
<%- include("../partials/footer", { flash }) %>
