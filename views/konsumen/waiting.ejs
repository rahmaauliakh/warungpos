<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900">
  <div class="mx-auto flex min-h-screen max-w-4xl items-center justify-center px-4 py-10 sm:px-6 lg:px-8">
    <section class="w-full overflow-hidden rounded-[32px] bg-white shadow-[0_32px_80px_rgba(15,23,42,0.10)] ring-1 ring-slate-200">
      <div class="bg-gradient-to-r from-slate-950 via-slate-900 to-slate-800 px-6 py-8 text-white sm:px-10">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.35em] text-slate-400">WarungPOS</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight">Menunggu Approve Kasir</h1>
            <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">
              Pesanan Anda sudah masuk ke sistem dan sedang menunggu konfirmasi dari kasir.
            </p>
          </div>
          <span class="inline-flex w-fit rounded-full bg-white/10 px-4 py-2 text-sm font-semibold text-white ring-1 ring-inset ring-white/20">
            <%= transaction.status_meta.label %>
          </span>
        </div>
      </div>

      <div class="grid gap-8 px-6 py-8 sm:px-10 lg:grid-cols-[120px_minmax(0,1fr)] lg:items-start">
        <div class="flex justify-center lg:justify-start">
          <div class="relative flex h-24 w-24 items-center justify-center">
            <div class="absolute inset-0 animate-ping rounded-full bg-sky-200 opacity-60"></div>
            <div class="absolute inset-2 animate-pulse rounded-full bg-sky-100"></div>
            <div class="relative flex h-16 w-16 items-center justify-center rounded-full bg-sky-500 text-white">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2M12 22a10 10 0 100-20 10 10 0 000 20z" />
              </svg>
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div class="grid gap-4 sm:grid-cols-3">
            <article class="rounded-3xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Invoice</p>
              <p class="mt-3 break-all text-base font-semibold text-slate-950"><%= transaction.invoice %></p>
            </article>
            <article class="rounded-3xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Total Belanja</p>
              <p class="mt-3 text-base font-semibold text-slate-950"><%= transaction.grand_total_formatted %></p>
            </article>
            <article class="rounded-3xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Waktu Order</p>
              <p class="mt-3 text-base font-semibold text-slate-950"><%= transaction.created_at_formatted %></p>
            </article>
          </div>

          <div class="rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-5">
            <p class="text-sm font-medium text-slate-700">Status saat ini</p>

            <% if (transaction.status === "rejected") { %>
              <div class="mt-3 rounded-2xl bg-rose-50 px-4 py-4 text-sm text-rose-700 ring-1 ring-rose-200">
                Transaksi ditolak. Silakan kembali ke katalog dan lakukan checkout ulang jika diperlukan.
              </div>
            <% } else if (transaction.status === "approved") { %>
              <div class="mt-3 rounded-2xl bg-sky-50 px-4 py-4 text-sm text-sky-700 ring-1 ring-sky-200">
                Pesanan sudah disetujui kasir. Struk pembayaran akan tersedia setelah pembayaran selesai diproses.
              </div>
            <% } else { %>
              <div class="mt-3 rounded-2xl bg-sky-50 px-4 py-4 text-sm text-sky-700 ring-1 ring-sky-200">
                Sistem akan memeriksa status transaksi setiap 5 detik sampai pesanan dikonfirmasi kasir.
              </div>
            <% } %>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="/konsumen" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
              Kembali ke Katalog
            </a>
            <a href="/konsumen/history" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
              Lihat Riwayat
            </a>
            <button type="button" onclick="window.location.reload()" class="rounded-2xl bg-slate-950 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
              Refresh Status
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <% if (["pending", "approved"].includes(transaction.status)) { %>
    <script>
      window.setTimeout(() => {
        window.location.reload();
      }, 5000);
    </script>
  <% } %>
</body>
</html>
