<%- include("../partials/header", { pageTitle, includeChartJs: true, bodyClass: "bg-slate-100 text-slate-900" }) %>
  <div class="min-h-screen lg:flex">
    <%- include("../partials/sidebar", {
      sidebarTitle: "Manager Panel",
      sidebarDescription: "Pantau KPI, transaksi, performa kasir, dan export laporan dari satu dashboard.",
      sidebarLinks: [
        { href: `/manager?filter=${activeFilter}#dashboard`, label: "Dashboard", short: "DB", matchPrefix: "/manager" }
      ],
      currentPath,
      sessionUser
    }) %>

    <main class="flex-1">
      <header class="border-b border-slate-200 bg-white/90 px-6 py-5 backdrop-blur">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Ringkasan operasional</p>
            <h2 class="mt-1 text-3xl font-semibold tracking-tight text-slate-950">Dashboard Manager</h2>
            <p class="mt-2 text-sm text-slate-500"><%= todayLabel %></p>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <% filters.forEach((item) => { %>
              <a
                href="/manager?filter=<%= item.key %>"
                class="rounded-2xl px-4 py-3 text-sm font-semibold transition <%= activeFilter === item.key ? 'bg-slate-950 text-white' : 'border border-slate-200 bg-slate-50 text-slate-700 hover:bg-white' %>"
              >
                <%= item.label %>
              </a>
            <% }) %>
            <a href="/manager/export/csv?filter=<%= activeFilter %>" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
              Export CSV
            </a>
            <a href="/manager/export/pdf?filter=<%= activeFilter %>" class="rounded-2xl bg-slate-950 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
              Export PDF
            </a>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 shadow-sm">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Status Sistem</p>
              <p class="mt-1 text-sm font-semibold text-emerald-600">POS Online</p>
            </div>
          </div>
        </div>
      </header>

      <section id="dashboard" class="px-6 py-6 scroll-mt-6">
        <% if (typeof dashboardError !== 'undefined' && dashboardError) { %>
          <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <%= dashboardError %>
          </div>
        <% } %>

        <div class="grid gap-5 xl:grid-cols-4">
          <% summaryCards.forEach((card) => { %>
            <article class="overflow-hidden rounded-3xl bg-white shadow-soft ring-1 ring-slate-200">
              <div class="bg-gradient-to-r <%= card.accent %> p-5 text-white">
                <p class="text-sm font-medium text-white/80"><%= card.title %></p>
                <h3 class="mt-4 text-3xl font-semibold tracking-tight"><%= card.value %></h3>
              </div>
              <div class="p-5">
                <p class="text-sm text-slate-500"><%= card.description %></p>
              </div>
            </article>
          <% }) %>
        </div>

        <div class="mt-6 space-y-6">
          <section id="laporan" class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200 scroll-mt-6">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-xl font-semibold text-slate-950">Laporan Penjualan</h3>
                <p class="mt-1 text-sm text-slate-500">
                  <% if (activeFilter === "today") { %>
                    Grafik total penjualan transaksi paid per jam untuk hari ini.
                  <% } else if (activeFilter === "week") { %>
                    Grafik total penjualan transaksi paid untuk rentang minggu ini.
                  <% } else if (activeFilter === "month") { %>
                    Grafik total penjualan transaksi paid untuk rentang bulan ini.
                  <% } else { %>
                    Grafik total penjualan transaksi paid untuk seluruh data yang tersedia.
                  <% } %>
                </p>
              </div>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                <%= chartRangeLabel %>
              </span>
            </div>

            <% if (chartData.labels.length === 0 || chartData.totals.every((value) => Number(value) === 0)) { %>
              <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-14 text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-white ring-1 ring-slate-200">
                  <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 19h16M7 16l3-3 2 2 5-6" />
                  </svg>
                </div>
                <h4 class="mt-4 text-lg font-semibold text-slate-950">Belum ada data penjualan</h4>
                <p class="mt-2 text-sm text-slate-500">Grafik akan terisi saat transaksi paid mulai tercatat.</p>
              </div>
            <% } else { %>
              <div class="mt-6 h-80">
                <canvas id="salesChart"></canvas>
              </div>
            <% } %>
          </section>

          <section id="aktivitas" class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200 scroll-mt-6">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-xl font-semibold text-slate-950">Transaksi Terbaru</h3>
                <p class="mt-1 text-sm text-slate-500">6 transaksi per halaman sesuai filter periode yang dipilih.</p>
              </div>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
                <%= recentTransactionsPagination.totalItems %> data
              </span>
            </div>

            <% if (recentTransactions.length === 0) { %>
              <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-14 text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-white ring-1 ring-slate-200">
                  <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V7a2 2 0 00-2-2H6a2 2 0 00-2 2v6m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4" />
                  </svg>
                </div>
                <h4 class="mt-4 text-lg font-semibold text-slate-950">Belum ada transaksi</h4>
                <p class="mt-2 text-sm text-slate-500">Transaksi terbaru akan tampil di sini saat data mulai masuk.</p>
              </div>
            <% } else { %>
            <div class="mt-6 overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead>
                  <tr class="text-left text-slate-500">
                    <th class="pb-3 font-medium">Invoice</th>
                    <th class="pb-3 font-medium">Konsumen</th>
                    <th class="pb-3 font-medium">Kasir</th>
                    <th class="pb-3 font-medium">Metode Bayar</th>
                    <th class="pb-3 font-medium">Total</th>
                    <th class="pb-3 font-medium">Status</th>
                    <th class="pb-3 font-medium">Tanggal</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <% recentTransactions.forEach((transaction) => { %>
                    <tr class="text-slate-700">
                      <td class="py-4 font-semibold text-slate-900"><%= transaction.invoice %></td>
                      <td class="py-4"><%= transaction.customer_name %></td>
                      <td class="py-4"><%= transaction.cashier_name %></td>
                      <td class="py-4"><%= transaction.payment_method %></td>
                      <td class="py-4 font-medium"><%= transaction.grand_total_formatted %></td>
                      <td class="py-4">
                        <span class="rounded-full px-3 py-1 text-xs font-semibold
                          <%= transaction.status === 'pending' ? 'bg-amber-100 text-amber-700' : '' %>
                          <%= transaction.status === 'approved' ? 'bg-sky-100 text-sky-700' : '' %>
                          <%= transaction.status === 'paid' ? 'bg-emerald-100 text-emerald-700' : '' %>
                          <%= transaction.status === 'rejected' ? 'bg-rose-100 text-rose-700' : '' %>
                        ">
                          <%= transaction.status %>
                        </span>
                      </td>
                      <td class="py-4"><%= transaction.created_at_formatted %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <% if (recentTransactionsPagination.totalPages > 1) { %>
              <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-4">
                <p class="text-sm text-slate-500">
                  Halaman <%= recentTransactionsPagination.currentPage %> dari <%= recentTransactionsPagination.totalPages %>
                </p>
                <div class="flex items-center gap-2">
                  <a
                    href="/manager?filter=<%= activeFilter %>&recentPage=<%= Math.max(1, recentTransactionsPagination.currentPage - 1) %>#aktivitas"
                    class="rounded-2xl border border-slate-200 px-4 py-2 text-sm font-semibold transition <%= recentTransactionsPagination.currentPage === 1 ? 'pointer-events-none bg-slate-100 text-slate-400' : 'bg-white text-slate-700 hover:bg-slate-50' %>"
                  >
                    Sebelumnya
                  </a>
                  <a
                    href="/manager?filter=<%= activeFilter %>&recentPage=<%= Math.min(recentTransactionsPagination.totalPages, recentTransactionsPagination.currentPage + 1) %>#aktivitas"
                    class="rounded-2xl border border-slate-200 px-4 py-2 text-sm font-semibold transition <%= recentTransactionsPagination.currentPage === recentTransactionsPagination.totalPages ? 'pointer-events-none bg-slate-100 text-slate-400' : 'bg-white text-slate-700 hover:bg-slate-50' %>"
                  >
                    Berikutnya
                  </a>
                </div>
              </div>
            <% } %>
            <% } %>
          </section>

          <section id="operasional" class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_360px] scroll-mt-6">
            <article class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200">
              <h3 class="text-xl font-semibold text-slate-950">Monitor Kasir</h3>
              <p class="mt-1 text-sm text-slate-500">Performa kasir berdasarkan transaksi paid pada periode yang sedang dipilih.</p>

              <% if (cashierMonitor.length === 0) { %>
                <div class="mt-5 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
                  <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-3xl bg-white ring-1 ring-slate-200">
                    <svg class="h-7 w-7 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5V4H2v16h5M9 20V10h6v10M9 6h6" />
                    </svg>
                  </div>
                  <h4 class="mt-4 text-base font-semibold text-slate-950">Belum ada performa kasir</h4>
                  <p class="mt-2 text-sm text-slate-500">Data kasir akan muncul setelah ada transaksi paid yang diproses.</p>
                </div>
              <% } else { %>
                <div class="mt-5 space-y-4">
                  <% cashierMonitor.forEach((cashier) => { %>
                    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <h4 class="text-base font-semibold text-slate-900"><%= cashier.cashier_name %></h4>
                          <p class="mt-1 text-sm text-slate-500"><%= cashier.total_transactions %> transaksi paid</p>
                        </div>
                        <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
                          Aktif
                        </span>
                      </div>

                      <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                        <div class="rounded-2xl bg-white p-3">
                          <p class="text-slate-500">Penjualan</p>
                          <p class="mt-1 font-semibold text-slate-900"><%= cashier.total_sales_formatted %></p>
                        </div>
                        <div class="rounded-2xl bg-white p-3">
                          <p class="text-slate-500">Fee</p>
                          <p class="mt-1 font-semibold text-slate-900"><%= cashier.total_fee_formatted %></p>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </article>

            <article class="rounded-3xl bg-gradient-to-br from-slate-900 via-slate-800 to-slate-700 p-6 text-white shadow-soft">
              <p class="text-sm font-medium text-slate-300">Insight Hari Ini</p>
              <h3 class="mt-2 text-2xl font-semibold">Pantau penjualan, transaksi, dan performa kasir dari data real-time database.</h3>
              <p class="mt-3 text-sm leading-6 text-slate-300">
                Filter periode memudahkan pembacaan performa harian, mingguan, bulanan, atau keseluruhan tanpa meninggalkan dashboard.
              </p>
            </article>
          </section>
        </div>
      </section>
    </main>
  </div>
<%- include("../partials/footer", {
  flash,
  extraScripts: chartData.labels.length > 0 && !chartData.totals.every((value) => Number(value) === 0) ? `
    <script>
      const chartElement = document.getElementById("salesChart");
      if (chartElement) {
        new Chart(chartElement, {
          type: "line",
          data: {
            labels: ${JSON.stringify(chartData.labels)},
            datasets: [{
              label: "Total Penjualan",
              data: ${JSON.stringify(chartData.totals)},
              borderColor: "#0f172a",
              backgroundColor: "rgba(15, 23, 42, 0.08)",
              fill: true,
              tension: 0.35,
              pointRadius: 4,
              pointBackgroundColor: "#0f172a"
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: {
                ticks: {
                  callback(value) {
                    return new Intl.NumberFormat("id-ID", {
                      style: "currency",
                      currency: "IDR",
                      maximumFractionDigits: 0
                    }).format(value);
                  }
                }
              }
            }
          }
        });
      }
    </script>
  ` : ""
}) %>
