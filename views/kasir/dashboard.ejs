<%- include("../partials/header", { pageTitle, bodyClass: "bg-[#f8fbff] text-slate-900", includeChartJs: true }) %>
  <div class="min-h-screen lg:flex">
    <%- include("../partials/sidebar", {
      sidebarTitle: "Kasir Dashboard",
      sidebarDescription: "Approve transaksi, tolak order, dan proses pembayaran dari satu layar kerja.",
      sidebarLinks: [
        { href: "/kasir", label: "Transaksi", short: "TR", matchPrefix: "/kasir" }
      ],
      currentPath,
      sessionUser
    }) %>

    <main class="flex-1">
      <header class="border-b border-blue-100 bg-white/90 px-6 py-5 backdrop-blur">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Cashier control center</p>
            <h2 class="mt-1 text-3xl font-semibold tracking-tight text-slate-950">Daftar Transaksi</h2>
            <p class="mt-2 text-sm text-slate-500">Buat transaksi langsung, pantau order konsumen, dan proses pembayaran dari satu layar.</p>
          </div>
        </div>
      </header>

      <section class="px-6 py-6">
        <% if (typeof dashboardError !== 'undefined' && dashboardError) { %>
          <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <%= dashboardError %>
          </div>
        <% } %>

        <section class="grid gap-4 xl:grid-cols-4">
          <% stats.forEach((stat) => { %>
            <article class="rounded-[24px] bg-white p-5 shadow-[0_20px_45px_rgba(15,23,42,0.08)] ring-1 ring-slate-200">
              <p class="text-sm font-medium text-slate-500"><%= stat.label %></p>
              <p class="mt-3 text-2xl font-semibold tracking-tight text-slate-950"><%= stat.value %></p>
              <p class="mt-1 text-sm text-slate-500"><%= stat.description %></p>
            </article>
          <% }) %>
        </section>

        <section class="mt-6 grid gap-6 xl:grid-cols-[minmax(0,1.35fr)_360px]">
          <section class="overflow-hidden rounded-[28px] bg-white shadow-[0_24px_60px_rgba(15,23,42,0.08)] ring-1 ring-slate-200">
            <div class="border-b border-slate-200 px-6 py-5">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <h3 class="text-xl font-semibold text-slate-950">Transaksi Kasir</h3>
                  <p class="mt-1 text-sm text-slate-500">Pilih produk untuk membuat transaksi langsung tanpa approval konsumen.</p>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= productPagination.totalItems %> produk</span>
              </div>
            </div>

            <form action="/kasir/direct-sale" method="POST" data-confirm="Pastikan produk, qty, metode bayar, dan total transaksi sudah benar. Lanjutkan transaksi ini?">
              <% if (products.length === 0) { %>
                <div class="px-6 py-12 text-center">
                  <h3 class="text-lg font-semibold text-slate-950">Produk belum tersedia</h3>
                  <p class="mt-2 text-sm text-slate-500">Tambahkan produk lewat operator sebelum membuat transaksi kasir.</p>
                </div>
              <% } else { %>
                <div class="grid gap-4 px-6 py-6 md:grid-cols-2 2xl:grid-cols-3">
                  <% products.forEach((product) => { %>
                    <article class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                      <input type="hidden" name="product_ids" value="<%= product.id %>">
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="truncate font-semibold text-slate-950"><%= product.nama_produk %></p>
                          <p class="mt-1 text-xs text-slate-500"><%= product.kategori || 'Umum' %></p>
                        </div>
                        <span class="rounded-full px-2.5 py-1 text-xs font-semibold <%= Number(product.stock) > 0 ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                          Stock <%= product.stock %>
                        </span>
                      </div>
                      <div class="mt-4 flex items-end justify-between gap-3">
                        <div>
                          <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Harga</p>
                          <p class="mt-1 text-base font-semibold text-slate-950"><%= product.harga_formatted %></p>
                        </div>
                        <div class="w-24">
                          <label class="mb-1 block text-xs font-medium text-slate-500">Qty</label>
                          <input
                            type="number"
                            min="0"
                            max="<%= product.stock %>"
                            step="1"
                            name="qty_<%= product.id %>"
                            value="0"
                            data-pos-qty
                            data-price="<%= product.harga_number %>"
                            class="w-full rounded-2xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold outline-none transition focus:border-slate-400"
                          >
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>

                <nav class="flex flex-col gap-3 border-t border-slate-200 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
                  <p class="text-sm text-slate-500">
                    Halaman <span class="font-semibold text-slate-900"><%= productPagination.currentPage %></span> dari <span class="font-semibold text-slate-900"><%= productPagination.totalPages %></span>
                  </p>
                  <div class="flex gap-2">
                    <a
                      href="/kasir?<%= new URLSearchParams({ productPage: productPagination.prevPage }).toString() %>"
                      class="rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-semibold transition <%= productPagination.hasPrev ? 'bg-white text-slate-700 hover:bg-slate-50' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
                    >
                      Sebelumnya
                    </a>
                    <a
                      href="/kasir?<%= new URLSearchParams({ productPage: productPagination.nextPage }).toString() %>"
                      class="rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-semibold transition <%= productPagination.hasNext ? 'border-blue-600 bg-blue-600 text-white hover:bg-blue-700' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
                    >
                      Berikutnya
                    </a>
                  </div>
                </nav>

                <div class="border-t border-slate-200 bg-slate-50 px-6 py-5">
                  <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_220px_auto] lg:items-end">
                    <div>
                      <p class="text-sm text-slate-500">Ringkasan Transaksi</p>
                      <div class="mt-2 grid gap-1 text-sm text-slate-600 sm:max-w-sm">
                        <div class="flex justify-between gap-4">
                          <span>Subtotal</span>
                          <span id="direct-sale-subtotal" class="font-semibold text-slate-900">Rp0</span>
                        </div>
                        <div class="flex justify-between gap-4">
                          <span>Fee POS 1%</span>
                          <span id="direct-sale-fee" class="font-semibold text-slate-900">Rp0</span>
                        </div>
                      </div>
                      <p id="direct-sale-total" class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">Rp0</p>
                    </div>
                    <div>
                      <label class="mb-2 block text-sm font-medium text-slate-700">Metode Bayar</label>
                      <select name="payment_method" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-slate-400" required>
                        <option value="">Pilih metode</option>
                        <option value="cash">Cash</option>
                        <option value="qris">QRIS</option>
                        <option value="transfer">Transfer</option>
                      </select>
                    </div>
                    <button type="submit" class="rounded-2xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
                      Buat Transaksi
                    </button>
                  </div>
                </div>
              <% } %>
            </form>
          </section>

          <section class="rounded-[28px] bg-white p-6 shadow-[0_24px_60px_rgba(15,23,42,0.08)] ring-1 ring-slate-200">
            <div>
              <h3 class="text-xl font-semibold text-slate-950">Status Transaksi</h3>
              <p class="mt-1 text-sm text-slate-500">Ringkasan status order saat ini.</p>
            </div>
            <div class="mt-6 h-72">
              <canvas id="kasirStatusChart"></canvas>
            </div>
          </section>
        </section>

        <section class="mt-6 overflow-hidden rounded-[28px] bg-white shadow-[0_24px_60px_rgba(15,23,42,0.08)] ring-1 ring-slate-200">
          <div class="border-b border-slate-200 px-6 py-5">
            <div class="flex items-center justify-between gap-4">
              <div>
                <h3 class="text-xl font-semibold text-slate-950">Transaksi Masuk</h3>
                <p class="mt-1 text-sm text-slate-500">Tinjau detail order dan proses pembayaran berdasarkan statusnya.</p>
              </div>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= transactionPagination.totalItems %> transaksi</span>
            </div>
          </div>

          <% if (transactions.length === 0) { %>
            <div class="px-6 py-14 text-center">
              <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-slate-100">
                <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V7a2 2 0 00-2-2H6a2 2 0 00-2 2v6m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4" />
                </svg>
              </div>
              <h3 class="mt-4 text-xl font-semibold text-slate-950">Belum ada transaksi</h3>
              <p class="mt-2 text-sm text-slate-500">Daftar transaksi akan muncul di sini setelah konsumen melakukan checkout.</p>
            </div>
          <% } else { %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50">
                  <tr class="text-left text-slate-500">
                    <th class="px-6 py-4 font-medium">Invoice</th>
                    <th class="px-6 py-4 font-medium">Nama Konsumen</th>
                    <th class="px-6 py-4 font-medium">Total</th>
                    <th class="px-6 py-4 font-medium">Status</th>
                    <th class="px-6 py-4 font-medium">Waktu</th>
                    <th class="px-6 py-4 font-medium">Aksi</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                  <% transactions.forEach((transaction) => { %>
                    <tr class="align-top">
                      <td class="px-6 py-4">
                        <p class="font-semibold text-slate-950"><%= transaction.invoice %></p>
                        <% if (transaction.payment_method) { %>
                          <p class="mt-1 text-xs uppercase tracking-[0.2em] text-slate-400"><%= transaction.payment_method %></p>
                        <% } %>
                      </td>
                      <td class="px-6 py-4">
                        <p class="font-medium text-slate-900"><%= transaction.customer_name %></p>
                        <p class="mt-1 text-xs text-slate-500"><%= transaction.customer_email || '-' %></p>
                      </td>
                      <td class="px-6 py-4 font-semibold text-slate-950"><%= transaction.grand_total_formatted %></td>
                      <td class="px-6 py-4">
                        <span class="rounded-full px-3 py-1 text-xs font-semibold
                          <%= transaction.status === 'pending' ? 'bg-amber-100 text-amber-700' : '' %>
                          <%= transaction.status === 'approved' ? 'bg-sky-100 text-sky-700' : '' %>
                          <%= transaction.status === 'paid' ? 'bg-emerald-100 text-emerald-700' : '' %>
                          <%= transaction.status === 'rejected' ? 'bg-rose-100 text-rose-700' : '' %>
                        ">
                          <%= transaction.status %>
                        </span>
                      </td>
                      <td class="px-6 py-4 text-slate-600"><%= transaction.created_at_formatted %></td>
                      <td class="px-6 py-4">
                        <div class="flex flex-wrap gap-2">
                          <button type="button" data-open-modal="detail-modal-<%= transaction.id %>" class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">
                            Detail
                          </button>

                          <% if (transaction.status === 'pending') { %>
                            <form action="/kasir/approve/<%= transaction.id %>" method="POST">
                              <button type="submit" class="rounded-xl bg-sky-50 px-3 py-2 text-xs font-semibold text-sky-700 transition hover:bg-sky-100">
                                Approve
                              </button>
                            </form>
                            <form action="/kasir/reject/<%= transaction.id %>" method="POST">
                              <button type="submit" class="rounded-xl bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-100">
                                Reject
                              </button>
                            </form>
                          <% } %>

                          <% if (transaction.status === 'approved') { %>
                            <button type="button" data-open-modal="pay-modal-<%= transaction.id %>" class="rounded-xl bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700 transition hover:bg-emerald-100">
                              Bayar
                            </button>
                          <% } %>

                          <% if (transaction.status === 'paid') { %>
                            <a href="/kasir/receipt/<%= transaction.id %>" class="rounded-xl bg-blue-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-blue-700">
                              Struk
                            </a>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <nav class="flex flex-col gap-3 border-t border-slate-200 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm text-slate-500">
              Halaman <span class="font-semibold text-slate-900"><%= transactionPagination.currentPage %></span> dari <span class="font-semibold text-slate-900"><%= transactionPagination.totalPages %></span>
              <span class="text-slate-400">(<%= transactionPagination.totalItems %> transaksi)</span>
            </p>
            <div class="flex gap-2">
              <a
                href="/kasir?<%= new URLSearchParams({ productPage: productPagination.currentPage, transactionPage: transactionPagination.prevPage }).toString() %>"
                class="rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-semibold transition <%= transactionPagination.hasPrev ? 'bg-white text-slate-700 hover:bg-slate-50' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
              >
                Sebelumnya
              </a>
              <a
                href="/kasir?<%= new URLSearchParams({ productPage: productPagination.currentPage, transactionPage: transactionPagination.nextPage }).toString() %>"
                class="rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-semibold transition <%= transactionPagination.hasNext ? 'border-blue-600 bg-blue-600 text-white hover:bg-blue-700' : 'pointer-events-none bg-slate-100 text-slate-400' %>"
              >
                Berikutnya
              </a>
            </div>
          </nav>
        </section>
      </section>
    </main>
  </div>

  <% transactions.forEach((transaction) => { %>
    <div id="detail-modal-<%= transaction.id %>" data-modal-overlay class="fixed inset-0 z-50 hidden items-center justify-center bg-blue-950/40 p-4">
      <div class="w-full max-w-3xl rounded-[28px] bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
        <div class="flex items-start justify-between gap-4 border-b border-slate-200 px-6 py-5">
          <div>
            <h3 class="text-2xl font-semibold text-slate-950">Detail Transaksi</h3>
            <p class="mt-1 text-sm text-slate-500"><%= transaction.invoice %> • <%= transaction.customer_name %></p>
          </div>
          <button type="button" data-close-modal="detail-modal-<%= transaction.id %>" class="rounded-xl bg-slate-100 p-2 text-slate-500 hover:bg-slate-200">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="px-6 py-6">
          <div class="overflow-hidden rounded-3xl border border-slate-200">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50">
                <tr class="text-left text-slate-500">
                  <th class="px-5 py-4 font-medium">Item</th>
                  <th class="px-5 py-4 font-medium">Qty</th>
                  <th class="px-5 py-4 font-medium">Harga</th>
                  <th class="px-5 py-4 font-medium">Subtotal</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 bg-white">
                <% transaction.items.forEach((item) => { %>
                  <tr>
                    <td class="px-5 py-4">
                      <p class="font-semibold text-slate-950"><%= item.nama_produk || 'Produk' %></p>
                      <p class="mt-1 text-xs text-slate-500"><%= item.kategori || 'Umum' %></p>
                    </td>
                    <td class="px-5 py-4 text-slate-700"><%= item.qty %></td>
                    <td class="px-5 py-4 text-slate-700"><%= item.price_formatted %></td>
                    <td class="px-5 py-4 font-semibold text-slate-950"><%= item.subtotal_formatted %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="mt-5 grid gap-4 sm:grid-cols-3">
            <article class="rounded-3xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Subtotal</p>
              <p class="mt-2 font-semibold text-slate-950"><%= transaction.subtotal_formatted %></p>
            </article>
            <article class="rounded-3xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Fee</p>
              <p class="mt-2 font-semibold text-slate-950"><%= transaction.fee_formatted %></p>
            </article>
            <article class="rounded-3xl bg-blue-600 p-4 text-white">
              <p class="text-xs uppercase tracking-[0.25em] text-blue-100/75">Grand Total</p>
              <p class="mt-2 font-semibold text-white"><%= transaction.grand_total_formatted %></p>
            </article>
          </div>
        </div>
      </div>
    </div>

    <% if (transaction.status === 'approved') { %>
      <div id="pay-modal-<%= transaction.id %>" data-modal-overlay class="fixed inset-0 z-50 hidden items-center justify-center bg-blue-950/40 p-4">
        <div class="w-full max-w-lg rounded-[28px] bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
          <div class="flex items-start justify-between gap-4 border-b border-slate-200 px-6 py-5">
            <div>
              <h3 class="text-2xl font-semibold text-slate-950">Proses Pembayaran</h3>
              <p class="mt-1 text-sm text-slate-500"><%= transaction.invoice %> • <%= transaction.grand_total_formatted %></p>
            </div>
            <button type="button" data-close-modal="pay-modal-<%= transaction.id %>" class="rounded-xl bg-slate-100 p-2 text-slate-500 hover:bg-slate-200">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <form action="/kasir/pay/<%= transaction.id %>" method="POST" class="px-6 py-6">
            <label class="mb-2 block text-sm font-medium text-slate-700">Metode Pembayaran</label>
            <select name="payment_method" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-slate-400 focus:bg-white" required>
              <option value="">Pilih metode pembayaran</option>
              <option value="cash">Cash</option>
              <option value="qris">QRIS</option>
              <option value="transfer">Transfer</option>
            </select>

            <div class="mt-6 flex justify-end gap-3">
              <button type="button" data-close-modal="pay-modal-<%= transaction.id %>" class="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700">
                Batal
              </button>
              <button type="submit" class="rounded-2xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
                Proses Bayar
              </button>
            </div>
          </form>
        </div>
      </div>
    <% } %>
  <% }) %>

  <script>
    const formatRupiah = (value) => new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      maximumFractionDigits: 0
    }).format(value);

    const DIRECT_SALE_FEE_RATE = 0.01;

    const updateDirectSaleTotal = () => {
      const subtotal = [...document.querySelectorAll("[data-pos-qty]")].reduce((sum, input) => {
        const qty = Number(input.value || 0);
        const price = Number(input.dataset.price || 0);
        return sum + (qty > 0 ? qty * price : 0);
      }, 0);
      const fee = Math.round(subtotal * DIRECT_SALE_FEE_RATE);
      const total = subtotal + fee;
      const subtotalTarget = document.getElementById("direct-sale-subtotal");
      const feeTarget = document.getElementById("direct-sale-fee");
      const totalTarget = document.getElementById("direct-sale-total");

      if (subtotalTarget) subtotalTarget.textContent = formatRupiah(subtotal);
      if (feeTarget) feeTarget.textContent = formatRupiah(fee);
      if (totalTarget) totalTarget.textContent = formatRupiah(total);
    };

    document.querySelectorAll("[data-pos-qty]").forEach((input) => {
      input.addEventListener("input", updateDirectSaleTotal);
    });
    updateDirectSaleTotal();

    const chartCanvas = document.getElementById("kasirStatusChart");
    if (chartCanvas && window.Chart) {
      new Chart(chartCanvas, {
        type: "doughnut",
        data: {
          labels: <%- JSON.stringify(statusChart.labels) %>,
          datasets: [{
            data: <%- JSON.stringify(statusChart.values) %>,
            backgroundColor: ["#f59e0b", "#60a5fa", "#10b981", "#f43f5e"],
            borderWidth: 0
          }]
        },
        options: {
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: "bottom"
            }
          },
          cutout: "62%"
        }
      });
    }

    const openModal = (modalId) => {
      const modal = document.getElementById(modalId);
      if (!modal) return;

      modal.classList.remove("hidden");
      modal.classList.add("flex");
    };

    const closeModal = (modalId) => {
      const modal = document.getElementById(modalId);
      if (!modal) return;

      modal.classList.add("hidden");
      modal.classList.remove("flex");
    };

    document.querySelectorAll("[data-open-modal]").forEach((button) => {
      button.addEventListener("click", () => openModal(button.dataset.openModal));
    });

    document.querySelectorAll("[data-close-modal]").forEach((button) => {
      button.addEventListener("click", () => closeModal(button.dataset.closeModal));
    });

    document.querySelectorAll("[data-modal-overlay]").forEach((modal) => {
      modal.addEventListener("click", (event) => {
        if (event.target === modal) {
          closeModal(modal.id);
        }
      });
    });
  </script>
<%- include("../partials/footer", { flash }) %>
